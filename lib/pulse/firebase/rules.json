{
  "rules": {
    "votes": {
      ".read": true,
      "$sessionId": {
        "$tagId": {
          ".write": false,
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
        }
      }
    },
    "userVotes": {
      "$sessionId": {
        "$userId": {
          "$tagId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": false,
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        }
      }
    },
    "mood": {
      ".read": true,
      "$pushId": {
        ".write": false,
        ".validate": "newData.hasChildren(['tagId','sessionId','userId','ts'])"
      }
    },
    "sessions": {
      ".read": true,
      ".write": false
    },
    "speakers": {
      ".read": true,
      ".write": false
    },
    "event": {
      ".read": true,
      ".write": false,
      "stats": {
        "registeredCount": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "geo": {
      ".read": true,
      "$city": {
        ".write": "auth != null",
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "speakerVotes": {
      ".read": true,
      "$speakerId": {
        "userVotes": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid && !data.exists()",
            ".validate": "newData.isString()"
          }
        },
        "counts": {
          "$tagId": {
            ".read": true,
            ".write": "auth != null",
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
          }
        }
      }
    },
    "participants": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name','consent','ts'])"
      }
    },
    "heartbeat": {
      "$dashboardId": {
        "lastSeen": {
          ".read": true,
          ".write": "auth != null"
        }
      }
    }
  }
}
