{
  "rules": {
    "votes": {
      ".read": true,
      "$sessionId": {
        "$tagId": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
        }
      }
    },
    "userVotes": {
      "$sessionId": {
        "$userId": {
          "$tagId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": "auth != null && auth.uid === $userId && !data.exists()",
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        }
      }
    },
    "mood": {
      ".read": true,
      "$pushId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['tagId','sessionId','userId','ts'])"
      }
    },
    "sessions": {
      ".read": true,
      ".write": "auth != null"
    },
    "speakers": {
      ".read": true,
      ".write": "auth != null"
    },
    "event": {
      ".read": true,
      ".write": "auth != null"
    },
    "heartbeat": {
      "$dashboardId": {
        "lastSeen": {
          ".read": true,
          ".write": "auth != null"
        }
      }
    }
  }
}
